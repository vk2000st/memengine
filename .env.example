# Database
DATABASE_URL=postgresql+asyncpg://memengine:memengine@localhost:5432/memengine

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LiteLLM / LLM provider
LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding model
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Postmark (for trace report email notifications)
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM=your-verified-sender@yourdomain.com
REPORT_EMAIL_TO=vibhanshu.karn@gmail.com

# Playground demo (pre-create company + agent once, then paste the key here)
# 1. POST /companies {"name": "Playground"} → copy api_key → DEMO_API_KEY
# 2. POST /agents {"agent_slug": "support-bot", ...} using that key
DEMO_API_KEY=
DEMO_AGENT_SLUG=support-bot

# App
APP_ENV=development
LOG_LEVEL=INFO
